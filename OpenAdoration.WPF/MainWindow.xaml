<Window x:Class="OpenAdoration.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
        Title="OpenAdoration"
        Icon="Assets/openadoration.ico"
        MinWidth="1024" MinHeight="600"
        Width="1280" Height="720"
        Background="{StaticResource PrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Menu bar ── -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Menu Background="Transparent">
                <MenuItem Header="Help">
                    <MenuItem Header="About OpenAdoration"
                              Click="OnAboutClick" />
                </MenuItem>
            </Menu>
        </Border>

        <!-- ── Content area (sidebar + page) ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <Border DockPanel.Dock="Top" Padding="16,20,16,12">
                        <StackPanel>
                            <TextBlock Text="OpenAdoration"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="Bold" />
                            <TextBlock Text="Worship Presenter"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Separator DockPanel.Dock="Top"
                               Background="{StaticResource BorderBrush}"
                               Margin="16,0" />

                    <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                        <Button Style="{StaticResource NavButton}"
                                Content="🎵  Songs"
                                Command="{Binding NavigateToSongsCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="📖  Bible"
                                Command="{Binding NavigateToBibleCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="📋  Service Schedule"
                                Command="{Binding NavigateToScheduleCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="🖼  Media"
                                Command="{Binding NavigateToMediaCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="🎨  Themes"
                                Command="{Binding NavigateToThemesCommand}" />
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- Page content -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentView}"
                            Background="{StaticResource SurfaceBrush}" />
        </Grid>

        <!-- ── Projection control bar ── -->
        <Border Grid.Row="2"
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- ── Preview thumbnail (16:9 miniature) ── -->
                <Border Grid.Column="0"
                        Width="112" Height="63"
                        Background="Black"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Margin="0,0,12,0">
                    <Grid>
                        <TextBlock Text="{Binding PreviewText}"
                                   Foreground="White"
                                   FontSize="7"
                                   FontFamily="Arial"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Padding="4"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />

                        <Border Background="#CC000000"
                                Visibility="{Binding PreviewIsBlank, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="BLANK"
                                       Foreground="#888888"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <Border Background="#CC0D0D14"
                                Visibility="{Binding IsProjecting, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Text="NO SIGNAL"
                                       Foreground="#444466"
                                       FontSize="8"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Current item info ── -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource AccentBrush}"
                                CornerRadius="2"
                                Padding="5,1"
                                Margin="0,0,6,0"
                                Visibility="{Binding IsProjecting, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="LIVE"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold" />
                        </Border>
                        <TextBlock Text="{Binding CurrentSongTitle}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding CurrentSlideLabel}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               Visibility="{Binding IsProjecting, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <!-- ── Transport controls + Open Screen ── -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <Button Content="Stage View"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnTogglePresenterClick"
                            Padding="12,8"
                            Margin="0,0,10,0" />

                    <Button Content="Open Screen"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnToggleScreenClick"
                            Padding="12,8"
                            Margin="0,0,10,0"
                            Visibility="{Binding IsScreenOpen, Converter={StaticResource InverseBoolToVis}}" />
                    <Button Content="Close Screen"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnToggleScreenClick"
                            Padding="12,8"
                            Margin="0,0,10,0"
                            Visibility="{Binding IsScreenOpen, Converter={StaticResource BoolToVis}}" />

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsProjecting, Converter={StaticResource BoolToVis}}">
                        <Button Content="◀"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding ProjectionPreviousCommand}"
                                Margin="0,0,4,0" />
                        <Button Content="▶"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding ProjectionNextCommand}"
                                Margin="0,0,4,0" />
                        <Button Content="Blank"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding ProjectionBlankCommand}"
                                Margin="0,0,4,0" />
                        <Button Content="Stop"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ProjectionStopCommand}" />
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
