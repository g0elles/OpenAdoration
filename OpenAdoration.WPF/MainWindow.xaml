<Window x:Class="OpenAdoration.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
        Title="OpenAdoration"
        MinWidth="1024" MinHeight="600"
        Width="1280" Height="720"
        Background="{StaticResource PrimaryBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- App header -->
                    <Border DockPanel.Dock="Top" Padding="16,20,16,12">
                        <StackPanel>
                            <TextBlock Text="OpenAdoration"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="Bold" />
                            <TextBlock Text="Worship Presenter"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Separator DockPanel.Dock="Top"
                               Background="{StaticResource BorderBrush}"
                               Margin="16,0" />

                    <!-- Navigation -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                        <Button Style="{StaticResource NavButton}"
                                Content="🎵  Songs"
                                Command="{Binding NavigateToSongsCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="📖  Bible"
                                Command="{Binding NavigateToBibleCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="📋  Service Schedule"
                                Command="{Binding NavigateToScheduleCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="🖼  Media"
                                Command="{Binding NavigateToMediaCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="🎨  Themes"
                                Command="{Binding NavigateToThemesCommand}" />
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- ── Content area ── -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentView}"
                            Background="{StaticResource SurfaceBrush}" />
        </Grid>

        <!-- ── Projection control bar ── -->
        <Border Grid.Row="1"
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Current slide info -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="PROJECTING"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="10"
                               FontWeight="Bold"
                               Visibility="{Binding IsProjecting, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding CurrentSlideLabel}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" />
                </StackPanel>

                <!-- Projection controls -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="◀  Previous"
                            Style="{StaticResource ProjectionButton}"
                            Command="{Binding ProjectionPreviousCommand}"
                            IsEnabled="{Binding IsProjecting}"
                            Margin="0,0,8,0" />
                    <Button Content="Next  ▶"
                            Style="{StaticResource ProjectionButton}"
                            Command="{Binding ProjectionNextCommand}"
                            IsEnabled="{Binding IsProjecting}"
                            Margin="0,0,8,0" />
                    <Button Content="Blank"
                            Style="{StaticResource ProjectionButton}"
                            Command="{Binding ProjectionBlankCommand}"
                            IsEnabled="{Binding IsProjecting}"
                            Margin="0,0,8,0" />
                    <Button Content="Stop"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ProjectionStopCommand}"
                            IsEnabled="{Binding IsProjecting}" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
