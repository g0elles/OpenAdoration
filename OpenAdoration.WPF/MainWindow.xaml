<Window x:Class="OpenAdoration.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
        xmlns:loc="clr-namespace:OpenAdoration.WPF.Localization"
        Title="OpenAdoration"
        Icon="Assets/openadoration.ico"
        MinWidth="1024" MinHeight="600"
        Width="1280" Height="720"
        Background="{StaticResource PrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Menu bar ── -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Menu Background="Transparent">
                <MenuItem Header="{loc:Loc Menu_Help}">
                    <MenuItem Header="{loc:Loc Menu_About}"
                              Click="OnAboutClick" />
                </MenuItem>
            </Menu>
        </Border>

        <!-- ── Content area (sidebar + page) ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <Border DockPanel.Dock="Top" Padding="16,20,16,12">
                        <StackPanel>
                            <TextBlock Text="OpenAdoration"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="Bold" />
                            <TextBlock Text="{loc:Loc App_Subtitle}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Separator DockPanel.Dock="Top"
                               Background="{StaticResource BorderBrush}"
                               Margin="16,0" />

                    <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                        <Button Style="{StaticResource NavButton}"
                                Content="{loc:Loc Nav_Songs}"
                                Command="{Binding NavigateToSongsCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="{loc:Loc Nav_Bible}"
                                Command="{Binding NavigateToBibleCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="{loc:Loc Nav_Schedule}"
                                Command="{Binding NavigateToScheduleCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="{loc:Loc Nav_Media}"
                                Command="{Binding NavigateToMediaCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="{loc:Loc Nav_Themes}"
                                Command="{Binding NavigateToThemesCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="{loc:Loc Nav_Stage}"
                                Command="{Binding NavigateToStageCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="{loc:Loc Nav_Plugins}"
                                Command="{Binding NavigateToPluginsCommand}" />
                        <Button Style="{StaticResource NavButton}"
                                Content="{loc:Loc Nav_Settings}"
                                Command="{Binding NavigateToSettingsCommand}" />
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- Page content -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentView}"
                            Background="{StaticResource SurfaceBrush}" />
        </Grid>

        <!-- ── Projection control bar ── -->
        <Border Grid.Row="2"
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- ── Current item info ── -->
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource AccentBrush}"
                                CornerRadius="2"
                                Padding="5,1"
                                Margin="0,0,6,0"
                                Visibility="{Binding IsProjecting, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{loc:Loc Live_Badge}"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold" />
                        </Border>
                        <TextBlock Text="{Binding CurrentSongTitle}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding CurrentSlideLabel}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               Visibility="{Binding IsProjecting, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <!-- ── Transport controls + Open Screen ── -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <!-- Live announcement -->
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="{loc:Loc Projection_AnnouncementPlaceholder}"
                             Width="170"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"
                             Text="{Binding AnnouncementText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="{loc:Loc Projection_Announce}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ShowAnnouncementCommand}"
                            Padding="10,8"
                            Margin="0,0,6,0" />
                    <Button Content="{loc:Loc Projection_Clear}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearAnnouncementCommand}"
                            Padding="10,8"
                            Margin="0,0,10,0"
                            Visibility="{Binding IsAnnouncementActive, Converter={StaticResource BoolToVis}}" />

                    <Button Content="{loc:Loc Projection_OpenScreen}"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnToggleScreenClick"
                            Padding="12,8"
                            Margin="0,0,10,0"
                            Visibility="{Binding IsScreenOpen, Converter={StaticResource InverseBoolToVis}}" />
                    <Button Content="{loc:Loc Projection_CloseScreen}"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnToggleScreenClick"
                            Padding="12,8"
                            Margin="0,0,10,0"
                            Visibility="{Binding IsScreenOpen, Converter={StaticResource BoolToVis}}" />

                    <!-- Video transport — only while a video slide is projected (M10.5) -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0"
                                Visibility="{Binding IsVideoSlideActive, Converter={StaticResource BoolToVis}}">
                        <Button Content="⏮"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding MediaRestartCommand}"
                                ToolTip="{loc:Loc Projection_Restart}"
                                Margin="0,0,4,0" />
                        <Button Content="⏪"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding MediaBackCommand}"
                                ToolTip="{loc:Loc Projection_Back}"
                                Margin="0,0,4,0" />
                        <Button Content="{Binding MediaPlayPauseGlyph}"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding MediaTogglePlayPauseCommand}"
                                ToolTip="{loc:Loc Projection_PlayPause}"
                                Margin="0,0,4,0" />
                        <Button Content="⏩"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding MediaForwardCommand}"
                                ToolTip="{loc:Loc Projection_Forward}"
                                Margin="0,0,6,0" />
                        <ProgressBar Width="120"
                                     Height="6"
                                     VerticalAlignment="Center"
                                     Minimum="0"
                                     Maximum="{Binding MediaDurationSeconds}"
                                     Value="{Binding MediaPositionSeconds}"
                                     Margin="0,0,6,0" />
                        <TextBlock Text="{Binding MediaTimeText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsProjecting, Converter={StaticResource BoolToVis}}">
                        <Button Content="◀"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding ProjectionPreviousCommand}"
                                Margin="0,0,4,0" />
                        <Button Content="▶"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding ProjectionNextCommand}"
                                Margin="0,0,4,0" />
                        <Button Content="{loc:Loc Projection_Blank}"
                                Style="{StaticResource ProjectionButton}"
                                Command="{Binding ProjectionBlankCommand}"
                                Margin="0,0,4,0" />
                        <Button Content="{loc:Loc Projection_Stop}"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ProjectionStopCommand}" />
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
