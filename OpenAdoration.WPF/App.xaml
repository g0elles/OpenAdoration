<Application x:Class="OpenAdoration.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:OpenAdoration.WPF.Converters"
             xmlns:views="clr-namespace:OpenAdoration.WPF.Views"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:conv="clr-namespace:OpenAdoration.WPF.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <ResourceDictionary Source="Styles/Base.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
            <converters:HexColorToBrushConverter x:Key="HexToBrush" />

            <!-- ViewModel → View mapping for ContentControl navigation -->
            <DataTemplate DataType="{x:Type vm:SongsViewModel}">
                <views:SongsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:BibleViewModel}">
                <views:BibleView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ServiceScheduleViewModel}">
                <views:ServiceScheduleView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MediaViewModel}">
                <views:MediaView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ThemeViewModel}">
                <views:ThemeView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>

</Application>
