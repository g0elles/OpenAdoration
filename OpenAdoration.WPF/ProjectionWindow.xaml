<Window x:Class="OpenAdoration.WPF.ProjectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenAdoration — Projection"
        Background="Black"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Focusable="False">

    <Grid>

        <!-- Theme background color — base canvas, always visible during projection -->
        <Rectangle x:Name="ThemeBackground" Fill="Black" />

        <!-- Theme background image — optional, sits above color layer -->
        <Image x:Name="ThemeBackgroundImage"
               Stretch="UniformToFill"
               Visibility="Collapsed" />

        <!-- Theme background video — ambient loop, always muted -->
        <MediaElement x:Name="ThemeBackgroundVideo"
                      LoadedBehavior="Manual"
                      Stretch="UniformToFill"
                      Visibility="Collapsed"
                      IsMuted="True"
                      MediaEnded="OnThemeVideoEnded"
                      MediaFailed="OnThemeVideoFailed" />

        <!-- Foreground content layers — opacity-animated on slide change for a fade transition.
             Theme background layers stay outside so they don't flicker between slides. -->
        <Grid x:Name="ContentLayers">

        <!-- Media image layer — for SlideType.Media with image files -->
        <Image x:Name="BackgroundImage"
               Stretch="Uniform"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Visibility="Collapsed" />

        <!-- Media video layer — for SlideType.Media with video files, plays with audio -->
        <MediaElement x:Name="ContentVideo"
                      LoadedBehavior="Manual"
                      Stretch="Uniform"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Visibility="Collapsed"
                      MediaOpened="OnContentVideoOpened"
                      MediaEnded="OnContentVideoEnded"
                      MediaFailed="OnContentVideoFailed" />

        <!-- 3-zone text layer: Header / Body / Footer -->
        <Grid x:Name="TextZoneGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header zone — token-resolved text, right-aligned by default -->
            <TextBlock x:Name="HeaderText"
                       Grid.Row="0"
                       Padding="30,10"
                       TextAlignment="Right"
                       TextWrapping="NoWrap"
                       Foreground="White"
                       FontFamily="Arial"
                       FontSize="28"
                       Visibility="Collapsed" />

            <!-- Body zone — main lyrics / verse content -->
            <Viewbox x:Name="TextViewbox"
                     Grid.Row="1"
                     Margin="60,20"
                     Stretch="Uniform">
                <TextBlock x:Name="SlideTextBlock"
                           Width="1760"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="White"
                           FontFamily="Arial"
                           FontSize="72"
                           LineHeight="96" />
            </Viewbox>

            <!-- Footer zone — token-resolved text, center-aligned by default -->
            <TextBlock x:Name="FooterText"
                       Grid.Row="2"
                       Padding="30,10"
                       TextAlignment="Center"
                       TextWrapping="NoWrap"
                       Foreground="White"
                       FontFamily="Arial"
                       FontSize="24"
                       Opacity="0.85"
                       Visibility="Collapsed" />
        </Grid>

        <!-- Blank overlay — covers everything when ShowBlank is active -->
        <Rectangle x:Name="BlankOverlay"
                   Fill="Black"
                   Visibility="Collapsed" />

        </Grid> <!-- end ContentLayers -->

        <!-- Corner label: fallback when theme has no HeaderTemplate (top-left, subtle) -->
        <StackPanel x:Name="CornerLabel"
                    Orientation="Horizontal"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"
                    Margin="14,10,0,0"
                    Panel.ZIndex="100"
                    Visibility="Collapsed">
            <TextBlock x:Name="CornerSongTitle"
                       FontFamily="Arial"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#CCFFFFFF" />
            <TextBlock Text="  ·  "
                       FontFamily="Arial"
                       FontSize="16"
                       Foreground="#66FFFFFF" />
            <TextBlock x:Name="CornerSectionLabel"
                       FontFamily="Arial"
                       FontSize="16"
                       Foreground="#99FFFFFF" />
        </StackPanel>

        <!-- Announcement banner: blue highlight overlaying the lower third; auto-dismissed -->
        <Border x:Name="AnnouncementBanner"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Margin="80,0,80,90"
                Padding="40,22"
                CornerRadius="10"
                Background="#2563EB"
                Panel.ZIndex="200"
                Visibility="Collapsed">
            <TextBlock x:Name="AnnouncementText"
                       Foreground="White"
                       FontFamily="Arial"
                       FontSize="44"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
        </Border>

    </Grid>
</Window>
