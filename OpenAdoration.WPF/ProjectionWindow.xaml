<Window x:Class="OpenAdoration.WPF.ProjectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenAdoration — Projection"
        Background="Black"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Focusable="False">

    <Grid>

        <!-- Media layer (images) — rendered below text -->
        <Image x:Name="BackgroundImage"
               Stretch="Uniform"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Visibility="Collapsed" />

        <!-- Text layer — Song lyrics and Bible verses -->
        <Viewbox x:Name="TextViewbox"
                 Margin="60,40"
                 Stretch="Uniform"
                 Visibility="Collapsed">
            <TextBlock x:Name="SlideTextBlock"
                       Width="1760"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="White"
                       FontFamily="Arial"
                       FontSize="72"
                       LineHeight="96" />
        </Viewbox>

        <!-- Blank overlay — covers everything when ShowBlank is active -->
        <Rectangle x:Name="BlankOverlay"
                   Fill="Black"
                   Visibility="Collapsed" />

    </Grid>
</Window>
