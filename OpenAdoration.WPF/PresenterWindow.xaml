<Window x:Class="OpenAdoration.WPF.PresenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stage View — OpenAdoration"
        Width="960" Height="540"
        MinWidth="640" MinHeight="360"
        Background="{StaticResource PrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Top bar: status + context + slide count ── -->
        <Border Grid.Row="0"
                Background="#12121E"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- LIVE / STOPPED badges -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Border x:Name="LiveBadge"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="3"
                            Padding="8,3"
                            Visibility="Collapsed">
                        <TextBlock Text="● LIVE"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="Bold" />
                    </Border>
                    <Border x:Name="StoppedBadge"
                            Background="{StaticResource BorderBrush}"
                            CornerRadius="3"
                            Padding="8,3">
                        <TextBlock Text="STOPPED"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   FontWeight="Bold" />
                    </Border>
                </StackPanel>

                <!-- Context label (song title / Bible reference) -->
                <TextBlock x:Name="ContextLabelText"
                           Grid.Column="1"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <!-- Slide position: N / Total -->
                <TextBlock x:Name="SlideCountText"
                           Grid.Column="2"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0" />
            </Grid>
        </Border>

        <!-- ── Content: current (2/3) | separator | next (1/3) ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Current slide -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Section label bar (e.g. "Verse 1" / "John 3:16") -->
                <Border Grid.Row="0"
                        Background="#12121E"
                        Padding="20,6">
                    <TextBlock x:Name="CurrentSectionLabel"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <!-- Slide text -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource PrimaryBrush}"
                              Padding="24,18">
                    <TextBlock x:Name="CurrentSlideText"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22"
                               LineHeight="34"
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>

            <!-- Column separator -->
            <Rectangle Grid.Column="1"
                       Fill="{StaticResource BorderBrush}" />

            <!-- Next slide -->
            <Grid Grid.Column="2" Background="#141422">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- "UP NEXT" header -->
                <Border Grid.Row="0"
                        Background="#0F0F1A"
                        Padding="16,8">
                    <TextBlock Text="UP NEXT"
                               Foreground="#666688"
                               FontSize="10"
                               FontWeight="Bold" />
                </Border>

                <!-- Next slide content / placeholder -->
                <Grid Grid.Row="1">
                    <TextBlock x:Name="NextEndPlaceholder"
                               Text="End of item"
                               Foreground="#444466"
                               FontSize="12"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Visible" />

                    <ScrollViewer x:Name="NextSlideScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16,12,16,16"
                                  Visibility="Collapsed">
                        <TextBlock x:Name="NextSlideText"
                                   Foreground="#B0B0CC"
                                   FontSize="14"
                                   LineHeight="22"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>

                <!-- Next section label -->
                <Border Grid.Row="2"
                        Background="#0F0F1A"
                        Padding="16,5">
                    <TextBlock x:Name="NextSectionLabel"
                               Foreground="#555577"
                               FontSize="10" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
