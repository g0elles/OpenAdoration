<UserControl x:Class="OpenAdoration.WPF.Views.AddEditThemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:loc="clr-namespace:OpenAdoration.WPF.Localization"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AddEditThemeViewModel}"
             Background="{DynamicResource SurfaceBrush}">

    <Grid>
        <!-- Busy overlay -->
        <Grid Panel.ZIndex="10"
              Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{loc:Loc Common_Saving}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <DockPanel>

            <!-- ── Footer ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource PrimaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource DangerBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="{loc:Loc Common_Cancel}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0" />
                        <Button x:Name="SaveThemeButton"
                                Content="{loc:Loc ThemeEdit_Save}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable form ── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,24">

                    <!-- Header -->
                    <TextBlock Text="{Binding FormTitle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <!-- ── Name ── -->
                    <TextBlock Text="{loc:Loc ThemeEdit_Name}" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="{loc:Loc ThemeEdit_NamePlaceholder}"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20" />

                    <!-- ── Font ── -->
                    <TextBlock Text="{loc:Loc ThemeEdit_Font}" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border Background="{DynamicResource PrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <!-- Family + Size -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc ThemeEdit_FontFamily}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4" />
                                    <ComboBox Style="{StaticResource FieldComboBox}"
                                              ItemsSource="{x:Static vm:AddEditThemeViewModel.AvailableFontFamilies}"
                                              SelectedItem="{Binding FontFamily}" />
                                </StackPanel>

                                <!-- Font size ± spinner -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Loc ThemeEdit_Size}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="−"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="12,8"
                                                Command="{Binding DecreaseFontSizeCommand}" />
                                        <TextBlock Text="{Binding FontSize}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="14"
                                                   MinWidth="38"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0" />
                                        <Button Content="+"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="12,8"
                                                Command="{Binding IncreaseFontSizeCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Font Color picker -->
                            <TextBlock Text="{loc:Loc ThemeEdit_FontColor}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <xctk:ColorPicker SelectedColor="{Binding FontColor}"
                                              Background="{DynamicResource PrimaryBrush}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              BorderBrush="{DynamicResource BorderBrush}"
                                              UsingAlphaChannel="False"
                                              ShowRecentColors="True"
                                              ShowAvailableColors="True"
                                              ColorMode="ColorCanvas"
                                              Height="32"
                                              Margin="0,0,0,12" />

                            <!-- Text Alignment -->
                            <TextBlock Text="{loc:Loc ThemeEdit_TextAlignment}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    ClipToBounds="True">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton Content="{loc:Loc ThemeEdit_AlignLeft}"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsAlignLeft, Mode=OneWay}"
                                                  Command="{Binding SetAlignmentCommand}"
                                                  CommandParameter="Left" />
                                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" />
                                    <ToggleButton Content="{loc:Loc ThemeEdit_AlignCenter}"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsAlignCenter, Mode=OneWay}"
                                                  Command="{Binding SetAlignmentCommand}"
                                                  CommandParameter="Center" />
                                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" />
                                    <ToggleButton Content="{loc:Loc ThemeEdit_AlignRight}"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsAlignRight, Mode=OneWay}"
                                                  Command="{Binding SetAlignmentCommand}"
                                                  CommandParameter="Right" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Background ── -->
                    <TextBlock Text="{loc:Loc ThemeEdit_Background}" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border Background="{DynamicResource PrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14"
                            Margin="0,0,0,16">
                        <StackPanel>

                            <!-- Background type selector -->
                            <TextBlock Text="{loc:Loc ThemeEdit_Type}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    ClipToBounds="True"
                                    Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton Content="{loc:Loc ThemeEdit_BgColor}"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsBackgroundColor, Mode=OneWay}"
                                                  Command="{Binding SetBackgroundTypeCommand}"
                                                  CommandParameter="Color" />
                                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" />
                                    <ToggleButton Content="{loc:Loc ThemeEdit_BgImage}"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsBackgroundImage, Mode=OneWay}"
                                                  Command="{Binding SetBackgroundTypeCommand}"
                                                  CommandParameter="Image" />
                                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" />
                                    <ToggleButton Content="{loc:Loc ThemeEdit_BgVideo}"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsBackgroundVideo, Mode=OneWay}"
                                                  Command="{Binding SetBackgroundTypeCommand}"
                                                  CommandParameter="Video" />
                                </StackPanel>
                            </Border>

                            <!-- Background Color (visible when type = Color) -->
                            <StackPanel Visibility="{Binding IsBackgroundColor, Converter={StaticResource BoolToVis}}">
                                <xctk:ColorPicker SelectedColor="{Binding BackgroundColor}"
                                                  Background="{DynamicResource PrimaryBrush}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                  UsingAlphaChannel="False"
                                                  ShowRecentColors="True"
                                                  ShowAvailableColors="True"
                                                  ColorMode="ColorCanvas"
                                                  Height="32" />
                            </StackPanel>

                            <!-- Background Image (visible when type = Image) -->
                            <Grid Visibility="{Binding IsBackgroundImage, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource FieldTextBox}"
                                         Tag="{loc:Loc ThemeEdit_NoImage}"
                                         IsReadOnly="True"
                                         Text="{Binding BackgroundImagePath}" />
                                <Button Grid.Column="2"
                                        Content="{loc:Loc Common_Browse}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,8"
                                        Click="OnBrowseImageClick" />
                                <Button Grid.Column="4"
                                        Content="✕"
                                        Style="{StaticResource IconDangerButton}"
                                        Click="OnClearImageClick"
                                        Visibility="{Binding HasBackgroundImage, Converter={StaticResource BoolToVis}}" />
                            </Grid>

                            <!-- Background Video (visible when type = Video) -->
                            <Grid Visibility="{Binding IsBackgroundVideo, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource FieldTextBox}"
                                         Tag="{loc:Loc ThemeEdit_NoVideo}"
                                         IsReadOnly="True"
                                         Text="{Binding BackgroundVideoPath}" />
                                <Button Grid.Column="2"
                                        Content="{loc:Loc Common_Browse}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,8"
                                        Click="OnBrowseVideoClick" />
                                <Button Grid.Column="4"
                                        Content="✕"
                                        Style="{StaticResource IconDangerButton}"
                                        Click="OnClearVideoClick"
                                        Visibility="{Binding HasBackgroundVideo, Converter={StaticResource BoolToVis}}" />
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Default toggle ── -->
                    <CheckBox Foreground="{DynamicResource TextPrimaryBrush}"
                              FontSize="13"
                              IsChecked="{Binding IsDefault}"
                              Margin="0,0,0,24"
                              Content="{loc:Loc ThemeEdit_UseDefault}" />

                    <!-- ── Slide transition ── -->
                    <TextBlock Text="{loc:Loc ThemeEdit_Transition}" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="TransitionCombo"
                              Style="{StaticResource FieldComboBox}"
                              Width="220" HorizontalAlignment="Left"
                              ItemsSource="{Binding AvailableTransitions}"
                              SelectedItem="{Binding SelectedTransition}"
                              Margin="0,0,0,24">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- ── Header / Footer templates ── -->
                    <TextBlock Text="{loc:Loc ThemeEdit_HeaderFooter}" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border Background="{DynamicResource PrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14"
                            Margin="0,0,0,16">
                        <StackPanel>

                            <!-- Info note -->
                            <Border Background="#1A7C6AF7"
                                    BorderBrush="#337C6AF7"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,7"
                                    Margin="0,0,0,12">
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap">
                                    <Run Text="{loc:Loc ThemeEdit_TokenNote1}" />
                                    <Run Text="{loc:Loc ThemeEdit_TokenNote2}" FontWeight="SemiBold" />
                                </TextBlock>
                            </Border>

                            <!-- Header template -->
                            <TextBlock Text="{loc:Loc ThemeEdit_HeaderTop}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="HeaderTemplateBox"
                                     Style="{StaticResource FieldTextBox}"
                                     Text="{Binding HeaderTemplate, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,6" />
                            <WrapPanel Margin="0,0,0,14">
                                <TextBlock Text="{loc:Loc ThemeEdit_Insert}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,4" />
                                <Button Content="{loc:Loc ThemeEdit_TokChurchName}"     Tag="[ChurchName]"       Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokSiteLicense}"    Tag="[SiteLicense]"      Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokSongTitle}"      Tag="[SongTitle]"        Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokSongAuthor}"     Tag="[SongAuthor]"       Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokSection}"         Tag="[SongVerseTag]"     Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokCopyright}"       Tag="[SongCopyright]"    Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokCcli}"        Tag="[SongCCLI]"         Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokVerseRef}"       Tag="[BibleReference]"   Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokBibleBook}"      Tag="[BibleBookName]"    Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokChapter}"       Tag="[BibleChapterID]"   Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokVerse}"         Tag="[BibleVerseID]"     Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokBibleVersion}"   Tag="[BibleDescription]" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                            </WrapPanel>

                            <!-- Footer template -->
                            <TextBlock Text="{loc:Loc ThemeEdit_FooterBottom}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="FooterTemplateBox"
                                     Style="{StaticResource FieldTextBox}"
                                     Text="{Binding FooterTemplate, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,6" />
                            <WrapPanel>
                                <TextBlock Text="{loc:Loc ThemeEdit_Insert}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,4" />
                                <Button Content="{loc:Loc ThemeEdit_TokChurchName}"     Tag="[ChurchName]"       Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokSiteLicense}"    Tag="[SiteLicense]"      Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokSongTitle}"      Tag="[SongTitle]"        Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokSongAuthor}"     Tag="[SongAuthor]"       Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokSection}"         Tag="[SongVerseTag]"     Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokCopyright}"       Tag="[SongCopyright]"    Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokCcli}"        Tag="[SongCCLI]"         Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokVerseRef}"       Tag="[BibleReference]"   Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokBibleBook}"      Tag="[BibleBookName]"    Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokChapter}"       Tag="[BibleChapterID]"   Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokVerse}"         Tag="[BibleVerseID]"     Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="{loc:Loc ThemeEdit_TokBibleVersion}"   Tag="[BibleDescription]" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                            </WrapPanel>

                        </StackPanel>
                    </Border>

                    <!-- ── Live Preview ── -->
                    <TextBlock Text="{loc:Loc ThemeEdit_Preview}" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            ClipToBounds="True"
                            HorizontalAlignment="Left">
                        <Viewbox Width="384" Height="216" Stretch="Uniform">
                            <Grid Width="1920" Height="1080">
                                <Rectangle Fill="{Binding BackgroundColor, Converter={StaticResource ColorToBrush}}" />
                                <Image Source="{Binding BackgroundImagePath, Converter={StaticResource FilePathToImage}}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding HasBackgroundImage, Converter={StaticResource BoolToVis}}" />
                                <!-- Video preview — static frame only (MediaElement is heavyweight) -->
                                <Border Background="#CC000000"
                                        Visibility="{Binding HasBackgroundVideo, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{loc:Loc ThemeEdit_VideoActive}"
                                               Foreground="#AAFFFFFF"
                                               FontSize="48"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{loc:Loc ThemeEdit_SampleLyrics}"
                                           FontFamily="{Binding FontFamily}"
                                           FontSize="{Binding FontSize}"
                                           Foreground="{Binding FontColor, Converter={StaticResource ColorToBrush}}"
                                           TextAlignment="{Binding TextAlignment}"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="120,80" />
                            </Grid>
                        </Viewbox>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
