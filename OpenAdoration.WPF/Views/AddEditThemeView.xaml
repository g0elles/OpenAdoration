<UserControl x:Class="OpenAdoration.WPF.Views.AddEditThemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AddEditThemeViewModel}"
             Background="{StaticResource SurfaceBrush}">

    <Grid>
        <!-- Busy overlay -->
        <Grid Panel.ZIndex="10"
              Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Saving…"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <DockPanel>

            <!-- ── Footer ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Save Theme"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable form ── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,24">

                    <!-- Header -->
                    <TextBlock Text="{Binding FormTitle}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <!-- Name -->
                    <TextBlock Text="NAME" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="Theme name"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14" />

                    <!-- Font Family + Size -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="FONT FAMILY" Style="{StaticResource FieldLabel}" />
                            <ComboBox Style="{StaticResource FieldComboBox}"
                                      ItemsSource="{x:Static vm:AddEditThemeViewModel.AvailableFontFamilies}"
                                      SelectedItem="{Binding FontFamily}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="SIZE (PT)" Style="{StaticResource FieldLabel}" />
                            <TextBox Style="{StaticResource FieldTextBox}"
                                     Tag="72"
                                     Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <!-- Font Color -->
                    <TextBlock Text="FONT COLOR" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource FieldTextBox}"
                                 Tag="#FFFFFF"
                                 Text="{Binding FontColor, UpdateSourceTrigger=PropertyChanged}" />
                        <Border Grid.Column="2"
                                CornerRadius="4"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Background="{Binding FontColor, Converter={StaticResource HexToBrush}}" />
                    </Grid>

                    <!-- Background Color -->
                    <TextBlock Text="BACKGROUND COLOR" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource FieldTextBox}"
                                 Tag="#000000"
                                 Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}" />
                        <Border Grid.Column="2"
                                CornerRadius="4"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Background="{Binding BackgroundColor, Converter={StaticResource HexToBrush}}" />
                    </Grid>

                    <!-- Background Image -->
                    <TextBlock Text="BACKGROUND IMAGE (OPTIONAL)" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource FieldTextBox}"
                                 Tag="Path to image file…"
                                 Text="{Binding BackgroundImagePath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                Content="Browse…"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,8"
                                Click="OnBrowseImageClick" />
                        <Button Grid.Column="4"
                                Content="✕"
                                Style="{StaticResource IconDangerButton}"
                                Click="OnClearImageClick"
                                Visibility="{Binding HasBackgroundImage, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                    <TextBlock Text="When set, the image is drawn over the background color."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0,0,0,14" />

                    <!-- Is Default -->
                    <CheckBox Foreground="{StaticResource TextPrimaryBrush}"
                              FontSize="13"
                              IsChecked="{Binding IsDefault}"
                              Margin="0,0,0,24"
                              Content="Use as default theme for all slides" />

                    <!-- Live Preview -->
                    <TextBlock Text="PREVIEW" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            ClipToBounds="True"
                            HorizontalAlignment="Left">
                        <!-- Fixed 16:9 container — Viewbox scales the 1920×1080 canvas to fit -->
                        <Viewbox Width="384" Height="216" Stretch="Uniform">
                            <Grid Width="1920" Height="1080">
                                <!-- Background color layer -->
                                <Rectangle Fill="{Binding BackgroundColor, Converter={StaticResource HexToBrush}}" />

                                <!-- Background image layer (optional) -->
                                <Image Source="{Binding BackgroundImagePath, Converter={StaticResource FilePathToImage}}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding HasBackgroundImage, Converter={StaticResource BoolToVis}}" />

                                <!-- Sample lyrics text -->
                                <TextBlock Text="Sample lyrics line one&#x0a;Second line of the song"
                                           FontFamily="{Binding FontFamily}"
                                           FontSize="{Binding FontSize}"
                                           Foreground="{Binding FontColor, Converter={StaticResource HexToBrush}}"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="120,80" />
                            </Grid>
                        </Viewbox>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
