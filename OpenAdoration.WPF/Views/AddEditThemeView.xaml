<UserControl x:Class="OpenAdoration.WPF.Views.AddEditThemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AddEditThemeViewModel}"
             Background="{StaticResource SurfaceBrush}">

    <Grid>
        <!-- Busy overlay -->
        <Grid Panel.ZIndex="10"
              Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Saving…"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <DockPanel>

            <!-- ── Footer ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Save Theme"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable form ── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,24">

                    <!-- Header -->
                    <TextBlock Text="{Binding FormTitle}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <!-- ── Name ── -->
                    <TextBlock Text="NAME" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="Theme name"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20" />

                    <!-- ── Font ── -->
                    <TextBlock Text="FONT" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource PrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <!-- Family + Size -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Font Family"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4" />
                                    <ComboBox Style="{StaticResource FieldComboBox}"
                                              ItemsSource="{x:Static vm:AddEditThemeViewModel.AvailableFontFamilies}"
                                              SelectedItem="{Binding FontFamily}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Size (pt)"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource FieldTextBox}"
                                             Tag="72"
                                             Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <!-- Font Color picker -->
                            <TextBlock Text="Font Color"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <xctk:ColorPicker SelectedColor="{Binding FontColor}"
                                              UsingAlphaChannel="False"
                                              ShowRecentColors="True"
                                              ShowAvailableColors="True"
                                              ColorMode="ColorCanvas"
                                              Height="32" />
                        </StackPanel>
                    </Border>

                    <!-- ── Background ── -->
                    <TextBlock Text="BACKGROUND" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource PrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14"
                            Margin="0,0,0,16">
                        <StackPanel>

                            <!-- Background Color -->
                            <TextBlock Text="Color"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <xctk:ColorPicker SelectedColor="{Binding BackgroundColor}"
                                              UsingAlphaChannel="False"
                                              ShowRecentColors="True"
                                              ShowAvailableColors="True"
                                              ColorMode="ColorCanvas"
                                              Height="32"
                                              Margin="0,0,0,14" />

                            <!-- Background Image -->
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4">
                                <Run Text="Background Image" />
                                <Run Text=" — overrides color" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
                            </TextBlock>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource FieldTextBox}"
                                         Tag="No image selected"
                                         IsReadOnly="True"
                                         Text="{Binding BackgroundImagePath}" />
                                <Button Grid.Column="2"
                                        Content="Browse…"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,8"
                                        Click="OnBrowseImageClick" />
                                <Button Grid.Column="4"
                                        Content="✕"
                                        Style="{StaticResource IconDangerButton}"
                                        Click="OnClearImageClick"
                                        Visibility="{Binding HasBackgroundImage, Converter={StaticResource BoolToVis}}" />
                            </Grid>

                            <!-- Background Video -->
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,8,0,4">
                                <Run Text="Background Video" />
                                <Run Text=" — overrides image" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
                            </TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource FieldTextBox}"
                                         Tag="No video selected"
                                         IsReadOnly="True"
                                         Text="{Binding BackgroundVideoPath}" />
                                <Button Grid.Column="2"
                                        Content="Browse…"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,8"
                                        Click="OnBrowseVideoClick" />
                                <Button Grid.Column="4"
                                        Content="✕"
                                        Style="{StaticResource IconDangerButton}"
                                        Click="OnClearVideoClick"
                                        Visibility="{Binding HasBackgroundVideo, Converter={StaticResource BoolToVis}}" />
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Default toggle ── -->
                    <CheckBox Foreground="{StaticResource TextPrimaryBrush}"
                              FontSize="13"
                              IsChecked="{Binding IsDefault}"
                              Margin="0,0,0,24"
                              Content="Use as default theme for all slides" />

                    <!-- ── Live Preview ── -->
                    <TextBlock Text="PREVIEW" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            ClipToBounds="True"
                            HorizontalAlignment="Left">
                        <Viewbox Width="384" Height="216" Stretch="Uniform">
                            <Grid Width="1920" Height="1080">
                                <Rectangle Fill="{Binding BackgroundColor, Converter={StaticResource ColorToBrush}}" />
                                <Image Source="{Binding BackgroundImagePath, Converter={StaticResource FilePathToImage}}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding HasBackgroundImage, Converter={StaticResource BoolToVis}}" />
                                <!-- Video preview — static frame only (MediaElement is heavyweight) -->
                                <Border Background="#CC000000"
                                        Visibility="{Binding HasBackgroundVideo, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="🎬  Video background active"
                                               Foreground="#AAFFFFFF"
                                               FontSize="48"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Sample lyrics line one&#x0a;Second line of the song"
                                           FontFamily="{Binding FontFamily}"
                                           FontSize="{Binding FontSize}"
                                           Foreground="{Binding FontColor, Converter={StaticResource ColorToBrush}}"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="120,80" />
                            </Grid>
                        </Viewbox>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
