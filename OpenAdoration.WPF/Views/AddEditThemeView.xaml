<UserControl x:Class="OpenAdoration.WPF.Views.AddEditThemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AddEditThemeViewModel}"
             Background="{StaticResource SurfaceBrush}">

    <Grid>
        <!-- Busy overlay -->
        <Grid Panel.ZIndex="10"
              Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Saving…"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <DockPanel>

            <!-- ── Footer ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Save Theme"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable form ── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,24">

                    <!-- Header -->
                    <TextBlock Text="{Binding FormTitle}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <!-- ── Name ── -->
                    <TextBlock Text="NAME" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="Theme name"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20" />

                    <!-- ── Font ── -->
                    <TextBlock Text="FONT" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource PrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <!-- Family + Size -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Font Family"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4" />
                                    <ComboBox Style="{StaticResource FieldComboBox}"
                                              ItemsSource="{x:Static vm:AddEditThemeViewModel.AvailableFontFamilies}"
                                              SelectedItem="{Binding FontFamily}" />
                                </StackPanel>

                                <!-- Font size ± spinner -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Size (pt)"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="−"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="12,8"
                                                Command="{Binding DecreaseFontSizeCommand}" />
                                        <TextBlock Text="{Binding FontSize}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"
                                                   MinWidth="38"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0" />
                                        <Button Content="+"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="12,8"
                                                Command="{Binding IncreaseFontSizeCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Font Color picker -->
                            <TextBlock Text="Font Color"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <xctk:ColorPicker SelectedColor="{Binding FontColor}"
                                              Background="{StaticResource PrimaryBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              BorderBrush="{StaticResource BorderBrush}"
                                              UsingAlphaChannel="False"
                                              ShowRecentColors="True"
                                              ShowAvailableColors="True"
                                              ColorMode="ColorCanvas"
                                              Height="32"
                                              Margin="0,0,0,12" />

                            <!-- Text Alignment -->
                            <TextBlock Text="Text Alignment"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    ClipToBounds="True">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton Content="Left"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsAlignLeft, Mode=OneWay}"
                                                  Command="{Binding SetAlignmentCommand}"
                                                  CommandParameter="Left" />
                                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" />
                                    <ToggleButton Content="Center"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsAlignCenter, Mode=OneWay}"
                                                  Command="{Binding SetAlignmentCommand}"
                                                  CommandParameter="Center" />
                                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" />
                                    <ToggleButton Content="Right"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsAlignRight, Mode=OneWay}"
                                                  Command="{Binding SetAlignmentCommand}"
                                                  CommandParameter="Right" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Background ── -->
                    <TextBlock Text="BACKGROUND" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource PrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14"
                            Margin="0,0,0,16">
                        <StackPanel>

                            <!-- Background type selector -->
                            <TextBlock Text="Type"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    ClipToBounds="True"
                                    Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton Content="Color"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsBackgroundColor, Mode=OneWay}"
                                                  Command="{Binding SetBackgroundTypeCommand}"
                                                  CommandParameter="Color" />
                                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" />
                                    <ToggleButton Content="Image"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsBackgroundImage, Mode=OneWay}"
                                                  Command="{Binding SetBackgroundTypeCommand}"
                                                  CommandParameter="Image" />
                                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" />
                                    <ToggleButton Content="Video"
                                                  Style="{StaticResource AlignToggleButton}"
                                                  IsChecked="{Binding IsBackgroundVideo, Mode=OneWay}"
                                                  Command="{Binding SetBackgroundTypeCommand}"
                                                  CommandParameter="Video" />
                                </StackPanel>
                            </Border>

                            <!-- Background Color (visible when type = Color) -->
                            <StackPanel Visibility="{Binding IsBackgroundColor, Converter={StaticResource BoolToVis}}">
                                <xctk:ColorPicker SelectedColor="{Binding BackgroundColor}"
                                                  Background="{StaticResource PrimaryBrush}"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  BorderBrush="{StaticResource BorderBrush}"
                                                  UsingAlphaChannel="False"
                                                  ShowRecentColors="True"
                                                  ShowAvailableColors="True"
                                                  ColorMode="ColorCanvas"
                                                  Height="32" />
                            </StackPanel>

                            <!-- Background Image (visible when type = Image) -->
                            <Grid Visibility="{Binding IsBackgroundImage, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource FieldTextBox}"
                                         Tag="No image selected"
                                         IsReadOnly="True"
                                         Text="{Binding BackgroundImagePath}" />
                                <Button Grid.Column="2"
                                        Content="Browse…"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,8"
                                        Click="OnBrowseImageClick" />
                                <Button Grid.Column="4"
                                        Content="✕"
                                        Style="{StaticResource IconDangerButton}"
                                        Click="OnClearImageClick"
                                        Visibility="{Binding HasBackgroundImage, Converter={StaticResource BoolToVis}}" />
                            </Grid>

                            <!-- Background Video (visible when type = Video) -->
                            <Grid Visibility="{Binding IsBackgroundVideo, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource FieldTextBox}"
                                         Tag="No video selected"
                                         IsReadOnly="True"
                                         Text="{Binding BackgroundVideoPath}" />
                                <Button Grid.Column="2"
                                        Content="Browse…"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,8"
                                        Click="OnBrowseVideoClick" />
                                <Button Grid.Column="4"
                                        Content="✕"
                                        Style="{StaticResource IconDangerButton}"
                                        Click="OnClearVideoClick"
                                        Visibility="{Binding HasBackgroundVideo, Converter={StaticResource BoolToVis}}" />
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── Default toggle ── -->
                    <CheckBox Foreground="{StaticResource TextPrimaryBrush}"
                              FontSize="13"
                              IsChecked="{Binding IsDefault}"
                              Margin="0,0,0,24"
                              Content="Use as default theme for all slides" />

                    <!-- ── Header / Footer templates ── -->
                    <TextBlock Text="HEADER / FOOTER" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource PrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14"
                            Margin="0,0,0,16">
                        <StackPanel>

                            <!-- Info note -->
                            <Border Background="#1A7C6AF7"
                                    BorderBrush="#337C6AF7"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,7"
                                    Margin="0,0,0,12">
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap">
                                    <Run Text="Token zones auto-hide when tokens have no value for the current slide type (e.g. a Bible header on a song slide). " />
                                    <Run Text="Any static text you type will always appear on every slide." FontWeight="SemiBold" />
                                </TextBlock>
                            </Border>

                            <!-- Header template -->
                            <TextBlock Text="Header (top)"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="HeaderTemplateBox"
                                     Style="{StaticResource FieldTextBox}"
                                     Text="{Binding HeaderTemplate, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,6" />
                            <WrapPanel Margin="0,0,0,14">
                                <TextBlock Text="Insert: "
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,4" />
                                <Button Content="Church Name"     Tag="[ChurchName]"       Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Site License"    Tag="[SiteLicense]"      Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Song Title"      Tag="[SongTitle]"        Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Song Author"     Tag="[SongAuthor]"       Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Section"         Tag="[SongVerseTag]"     Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Copyright"       Tag="[SongCopyright]"    Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="CCLI No."        Tag="[SongCCLI]"         Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Verse Ref"       Tag="[BibleReference]"   Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Bible Book"      Tag="[BibleBookName]"    Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Chapter #"       Tag="[BibleChapterID]"   Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Verse #"         Tag="[BibleVerseID]"     Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                                <Button Content="Bible Version"   Tag="[BibleDescription]" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertHeaderToken" />
                            </WrapPanel>

                            <!-- Footer template -->
                            <TextBlock Text="Footer (bottom)"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="FooterTemplateBox"
                                     Style="{StaticResource FieldTextBox}"
                                     Text="{Binding FooterTemplate, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,6" />
                            <WrapPanel>
                                <TextBlock Text="Insert: "
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,4" />
                                <Button Content="Church Name"     Tag="[ChurchName]"       Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Site License"    Tag="[SiteLicense]"      Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Song Title"      Tag="[SongTitle]"        Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Song Author"     Tag="[SongAuthor]"       Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Section"         Tag="[SongVerseTag]"     Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Copyright"       Tag="[SongCopyright]"    Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="CCLI No."        Tag="[SongCCLI]"         Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Verse Ref"       Tag="[BibleReference]"   Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Bible Book"      Tag="[BibleBookName]"    Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Chapter #"       Tag="[BibleChapterID]"   Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Verse #"         Tag="[BibleVerseID]"     Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                                <Button Content="Bible Version"   Tag="[BibleDescription]" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="6,2" Margin="0,0,4,4" Click="OnInsertFooterToken" />
                            </WrapPanel>

                        </StackPanel>
                    </Border>

                    <!-- ── Live Preview ── -->
                    <TextBlock Text="PREVIEW" Style="{StaticResource FieldLabel}" Margin="0,0,0,8" />
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            ClipToBounds="True"
                            HorizontalAlignment="Left">
                        <Viewbox Width="384" Height="216" Stretch="Uniform">
                            <Grid Width="1920" Height="1080">
                                <Rectangle Fill="{Binding BackgroundColor, Converter={StaticResource ColorToBrush}}" />
                                <Image Source="{Binding BackgroundImagePath, Converter={StaticResource FilePathToImage}}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding HasBackgroundImage, Converter={StaticResource BoolToVis}}" />
                                <!-- Video preview — static frame only (MediaElement is heavyweight) -->
                                <Border Background="#CC000000"
                                        Visibility="{Binding HasBackgroundVideo, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="🎬  Video background active"
                                               Foreground="#AAFFFFFF"
                                               FontSize="48"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Sample lyrics line one&#x0a;Second line of the song"
                                           FontFamily="{Binding FontFamily}"
                                           FontSize="{Binding FontSize}"
                                           Foreground="{Binding FontColor, Converter={StaticResource ColorToBrush}}"
                                           TextAlignment="{Binding TextAlignment}"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="120,80" />
                            </Grid>
                        </Viewbox>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
