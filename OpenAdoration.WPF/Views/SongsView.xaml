<UserControl x:Class="OpenAdoration.WPF.Views.SongsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:views="clr-namespace:OpenAdoration.WPF.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SongsViewModel}"
             Loaded="OnLoaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════ LEFT: Song list ══ -->
        <Grid Grid.Column="0"
              Background="{StaticResource PrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Search + New button header -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,1"
                    Padding="12,12,12,10">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Songs"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="+ New"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding NewSongCommand}"
                                Padding="10,6" />
                    </Grid>

                    <!-- Search -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource SearchTextBox}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,6,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Content="🔍"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding SearchCommand}"
                                Padding="8,6" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Song list -->
            <Border Grid.Row="1"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <!-- Loading indicator -->
                    <TextBlock Text="Loading…"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

                    <!-- Error -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="12"
                               VerticalAlignment="Top"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />

                    <!-- Empty state -->
                    <TextBlock Text="No songs yet. Click + New to add one."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBusy}"        Value="False" />
                                            <Condition Binding="{Binding HasError}"       Value="False" />
                                            <Condition Binding="{Binding Songs.Count}"    Value="0" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Song rows -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Songs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SongRowCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Title + action buttons -->
                                            <Grid Grid.Row="0">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right">
                                                    <Button Content="▶"
                                                            Style="{StaticResource IconButton}"
                                                            ToolTip="Project"
                                                            Command="{Binding DataContext.ProjectSongCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="✎"
                                                            Style="{StaticResource IconButton}"
                                                            ToolTip="Edit"
                                                            Command="{Binding DataContext.EditSongCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="2,0" />
                                                    <Button Content="✕"
                                                            Style="{StaticResource IconDangerButton}"
                                                            ToolTip="Delete"
                                                            Command="{Binding DataContext.DeleteSongCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- Author -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Author}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Author}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Author}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Classification -->
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Classification}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="10"
                                                       Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Classification}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Classification}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════ RIGHT: Edit / Placeholder ══ -->

        <!-- Add/Edit form (visible when IsEditing = true) -->
        <views:AddEditSongView Grid.Column="1"
                               DataContext="{Binding EditViewModel}"
                               Visibility="{Binding DataContext.IsEditing,
                                            RelativeSource={RelativeSource AncestorType=UserControl},
                                            Converter={StaticResource BoolToVis}}" />

        <!-- Placeholder (visible when IsEditing = false) -->
        <Grid Grid.Column="1"
              Background="{StaticResource SurfaceBrush}"
              Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Select a song from the list"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="16"
                           HorizontalAlignment="Center" />
                <TextBlock Text="or click + New to create one"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
