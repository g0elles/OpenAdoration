<UserControl x:Class="OpenAdoration.WPF.Views.ServiceScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             Loaded="OnLoaded">

    <Grid Background="{StaticResource SurfaceBrush}">

        <!-- ══════════════════════════════════════════════ PANEL 1: SERVICE LIST -->
        <Grid Visibility="{Binding IsServiceOpen, Converter={StaticResource InverseBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- header bar -->
                <RowDefinition Height="Auto" /> <!-- create form (collapsible) -->
                <RowDefinition Height="*"    /> <!-- service list -->
                <RowDefinition Height="Auto" /> <!-- error banner -->
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <Grid>
                    <TextBlock Text="Service Schedule"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Content="+ New Service"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ShowCreateFormCommand}"
                            HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- Create form -->
            <Border Grid.Row="1"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12"
                    Visibility="{Binding IsCreatingService, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Style="{StaticResource FieldTextBox}"
                             Tag="Service name (e.g. Sunday 11am)"
                             Text="{Binding NewServiceName, UpdateSourceTrigger=PropertyChanged}" />
                    <DatePicker Grid.Column="2"
                                SelectedDate="{Binding NewServiceDate}"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                FontSize="13" />
                    <Button Grid.Column="4"
                            Content="Create"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ConfirmCreateServiceCommand}" />
                    <Button Grid.Column="6"
                            Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCreateCommand}" />
                </Grid>
            </Border>

            <!-- Service list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Services}" Margin="16,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ServiceScheduleViewModel}">
                            <Border Style="{StaticResource SongRowCard}" Margin="0,0,0,4" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:dddd, MMMM d, yyyy}'}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Open"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding DataContext.OpenServiceCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="3"
                                            Content="✕"
                                            Style="{StaticResource IconDangerButton}"
                                            Command="{Binding DataContext.DeleteServiceCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasNoServices, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="No services yet."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="15" HorizontalAlignment="Center" />
                <TextBlock Text="Click &quot;+ New Service&quot; to get started."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>

            <!-- Error banner -->
            <Border Grid.Row="3"
                    Background="#3E1A1A"
                    BorderBrush="{StaticResource DangerBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,10"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="13" TextWrapping="Wrap" />
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════ PANEL 2: SCHEDULE BUILDER -->
        <Grid Visibility="{Binding IsBuilding, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- header bar -->
                <RowDefinition Height="Auto" /> <!-- toolbar -->
                <RowDefinition Height="Auto" /> <!-- add panels (collapsible) -->
                <RowDefinition Height="*"    /> <!-- schedule items -->
                <RowDefinition Height="Auto" /> <!-- error banner -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="◀ Back"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CloseServiceCommand}" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding OpenedService.Name}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding OpenedService.Date, StringFormat='{}{0:MMMM d, yyyy}'}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>
                    <Button Grid.Column="3"
                            Content="▶ Start Service"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartLiveCommand}" />
                </Grid>
            </Border>

            <!-- Toolbar: Add buttons -->
            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ Add Song"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ShowAddSongPanelCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="+ Add Bible"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ShowAddBiblePanelCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="+ Add Media"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ShowAddMediaPanelCommand}"
                            Margin="0,0,8,0" />
                </StackPanel>
            </Border>

            <!-- Add panels (collapsible) -->
            <Border Grid.Row="2"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAddingSong}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAddingBible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAddingMedia}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <!-- Only one child allowed in Border — wrap both panels in a Grid -->
                <Grid>

                <!-- Add Song panel -->
                <Grid Visibility="{Binding IsAddingSong, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="160" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0"
                             Style="{StaticResource FieldTextBox}"
                             Tag="Search songs…"
                             Text="{Binding SongPickerSearchTerm, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" />
                    <Border Grid.Row="1"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ListBox ItemsSource="{Binding SongPickerResults}"
                                 SelectedItem="{Binding PickerSelectedSong}"
                                 DisplayMemberPath="Title"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    <Setter Property="Padding"    Value="10,6" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ActiveNavBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Add Selected"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ConfirmAddSongCommand}"
                                IsEnabled="{Binding CanConfirmAddSong}"
                                Margin="0,0,8,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelAddSongCommand}" />
                    </StackPanel>
                </Grid>

                <!-- Add Bible panel -->
                <Grid Visibility="{Binding IsAddingBible, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Version + Book + Chapter -->
                        <RowDefinition Height="Auto" />  <!-- Selection hint -->
                        <RowDefinition Height="160" />   <!-- Verse list -->
                        <RowDefinition Height="Auto" />  <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Version, Book, Chapter in one row -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="VERSION" Style="{StaticResource FieldLabel}" />
                            <ComboBox Style="{StaticResource FieldComboBox}"
                                      ItemsSource="{Binding BibleVersions}"
                                      SelectedItem="{Binding SelectedAddBibleVersion}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="BOOK" Style="{StaticResource FieldLabel}" />
                            <ComboBox Style="{StaticResource FieldComboBox}"
                                      ItemsSource="{Binding AddBibleBooks}"
                                      SelectedItem="{Binding SelectedAddBibleBook}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="CHAPTER" Style="{StaticResource FieldLabel}" />
                            <ComboBox Style="{StaticResource FieldComboBox}"
                                      ItemsSource="{Binding AddBibleChapters}"
                                      SelectedItem="{Binding SelectedAddBibleChapterNumber}" />
                        </StackPanel>
                    </Grid>

                    <!-- Row 1: Selection hint / label -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding BiblePickerSelectionLabel}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,0,0,6" />

                    <!-- Row 2: Verse list -->
                    <Border Grid.Row="2"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Margin="0,0,0,8"
                            ClipToBounds="True">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding AddBibleVerses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button HorizontalContentAlignment="Stretch"
                                                Padding="0" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.SelectVerseInPickerCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="VerseBd"
                                                            Background="Transparent"
                                                            Padding="10,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="28" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Number}"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Preview}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="12"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsInRange}" Value="True">
                                                            <Setter TargetName="VerseBd" Property="Background"
                                                                    Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="VerseBd" Property="Background"
                                                                    Value="{StaticResource ActiveNavBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Row 3: Buttons -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                        <Button Content="Add"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ConfirmAddBibleCommand}"
                                IsEnabled="{Binding CanConfirmAddBible}"
                                Margin="0,0,8,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelAddBibleCommand}" />
                    </StackPanel>
                </Grid>

                <!-- Add Media panel -->
                <Grid Visibility="{Binding IsAddingMedia, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="160" />  <!-- Media file list -->
                        <RowDefinition Height="Auto" /> <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Margin="0,0,0,8">
                        <ListBox ItemsSource="{Binding MediaPickerFiles}"
                                 SelectedItem="{Binding PickerSelectedMedia}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    <Setter Property="Padding"    Value="10,7" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ActiveNavBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="🖼" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Video">
                                                            <Setter Property="Text" Value="🎬" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <Button Content="Add Selected"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ConfirmAddMediaCommand}"
                                IsEnabled="{Binding CanConfirmAddMedia}"
                                Margin="0,0,8,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelAddMediaCommand}" />
                    </StackPanel>
                </Grid>

                </Grid> <!-- end wrapping Grid for add panels -->
            </Border>

            <!-- Schedule item list -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ScheduleItems}" Margin="16,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ScheduleItemViewModel}">
                            <Border Style="{StaticResource SongRowCard}"
                                    Margin="0,0,0,4" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TypeIcon}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DisplayTitle}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="13"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                                        <Button Content="▲"
                                                Style="{StaticResource IconButton}"
                                                Command="{Binding MoveUpCommand}"
                                                IsEnabled="{Binding CanMoveUp}"
                                                Margin="0,0,2,0" />
                                        <Button Content="▼"
                                                Style="{StaticResource IconButton}"
                                                Command="{Binding MoveDownCommand}"
                                                IsEnabled="{Binding CanMoveDown}"
                                                Margin="0,0,2,0" />
                                        <Button Content="✕"
                                                Style="{StaticResource IconDangerButton}"
                                                Command="{Binding DeleteCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state for builder -->
            <StackPanel Grid.Row="3"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasNoScheduleItems, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="No items yet."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="15" HorizontalAlignment="Center" />
                <TextBlock Text="Use the toolbar to add songs and Bible passages."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>

            <!-- Error banner -->
            <Border Grid.Row="4"
                    Background="#3E1A1A"
                    BorderBrush="{StaticResource DangerBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,10"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="13" TextWrapping="Wrap" />
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════ PANEL 3: LIVE MODE -->
        <Grid Visibility="{Binding IsLiveMode, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- header -->
                <RowDefinition Height="*"    /> <!-- main area -->
                <RowDefinition Height="Auto" /> <!-- bottom nav bar -->
            </Grid.RowDefinitions>

            <!-- Live header -->
            <Border Grid.Row="0"
                    Background="#1E2E1E"
                    BorderBrush="#3A5A3A"
                    BorderThickness="0,0,0,1"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="■ Stop"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding StopLiveCommand}" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding OpenedService.Name}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="● LIVE"
                                   Foreground="#4CAF50"
                                   FontSize="11" FontWeight="Bold" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main: schedule list (left) + context (right) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="1"  />
                    <ColumnDefinition Width="*"  />
                </Grid.ColumnDefinitions>

                <!-- Left: item list -->
                <ScrollViewer Grid.Column="0"
                              Background="{StaticResource PrimaryBrush}"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ScheduleItems}" Margin="8,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ScheduleItemViewModel}">
                                <Button Command="{Binding SelectCommand}"
                                        Margin="0,0,0,2"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Left"
                                        Cursor="Hand"
                                        Padding="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="Transparent"
                                                    CornerRadius="4"
                                                    Padding="10,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20" />
                                                        <ColumnDefinition Width="6" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding TypeIcon}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontSize="13"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding DisplayTitle}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentLiveItem}" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource ActiveNavBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Separator -->
                <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}" />

                <!-- Right: current item context -->
                <Border Grid.Column="2"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="24">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Now projecting:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding CurrentLiveItemTitle}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="18" FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Use the main navigation bar (Next / Prev) to move between slides."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,16,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom nav bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="◀ Prev Item"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding PrevItemCommand}"
                                Margin="0,0,12,0" />
                        <Button Content="Next Item ▶"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding NextItemCommand}" />
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12">
                        <Run Text="{Binding CurrentLiveDisplayNumber, StringFormat='Item {0}', Mode=OneWay}" />
                        <Run Text=" of " />
                        <Run Text="{Binding ScheduleItems.Count, Mode=OneWay}" />
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>

        <!-- IsBusy overlay (shared across all panels) -->
        <Grid Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading…"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="16" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
