<Window x:Class="OpenAdoration.WPF.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OpenAdoration.WPF.Localization"
        Title="{loc:Loc Menu_About}"
        Width="440" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}">

    <StackPanel Margin="32,28,32,28">

        <!-- Identity -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
            <Border Width="56" Height="56"
                    CornerRadius="28"
                    Background="{DynamicResource AccentBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,12">
                <TextBlock Text="✝"
                           Foreground="White"
                           FontSize="26"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
            <TextBlock x:Name="AppNameText"
                       Text="OpenAdoration"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="VersionText"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,3,0,0" />
            <TextBlock Text="{loc:Loc About_Tagline}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0" />
        </StackPanel>

        <!-- Keyboard shortcuts -->
        <Border Background="{DynamicResource PrimaryBrush}"
                CornerRadius="6"
                Padding="16,12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="{loc:Loc About_ShortcutsHeader}"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="10" FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Space / → / PgDn"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,2" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{loc:Loc About_NextSlide}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="← / PgUp"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,2" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{loc:Loc About_PrevSlide}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="B"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,2" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{loc:Loc About_BlankScreen}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Esc"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,2" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{loc:Loc About_StopProjection}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="1 – 9"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,2" />
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{loc:Loc About_JumpToSlide}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Ctrl + 1–5"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,2" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{loc:Loc About_NavigateTabs}"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,2" />
            </Grid>
        </Border>

        <!-- License -->
        <TextBlock Text="{loc:Loc About_License}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />

    </StackPanel>
</Window>
