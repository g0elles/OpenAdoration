<UserControl x:Class="OpenAdoration.WPF.Views.PluginsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:OpenAdoration.WPF.Localization"
             Loaded="OnLoaded">

    <Grid Background="{DynamicResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
            <TextBlock Text="{loc:Loc Plugins_Title}" Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Installed list -->
            <DockPanel Grid.Column="0" Margin="0,0,16,0">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="AddPluginButton" Content="{loc:Loc Plugins_Add}" Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddPluginCommand}" />
                    <Button x:Name="RemovePluginButton" Content="{loc:Loc Plugins_Remove}" Style="{StaticResource DangerButton}"
                            Margin="8,0,0,0" Command="{Binding RemovePluginCommand}"
                            IsEnabled="{Binding HasSelection}" />
                </StackPanel>
                <ListBox x:Name="InstalledPluginsList" ItemsSource="{Binding InstalledPlugins}" SelectedItem="{Binding SelectedPlugin}"
                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" />
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11">
                                    <Run Text="v" /><Run Text="{Binding Version, Mode=OneWay}" />
                                    <Run Text="  ·  " /><Run Text="{Binding Capability, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Selected plugin detail -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedPlugin.Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <!-- Settings -->
                    <TextBlock Text="{loc:Loc Plugins_Settings}" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Settings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Label}" Style="{StaticResource FieldLabel}" />
                                    <TextBox Style="{StaticResource FieldTextBox}" Width="340" HorizontalAlignment="Left"
                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding Secret, Converter={StaticResource InverseBoolToVis}}" />
                                    <PasswordBox Width="340" HorizontalAlignment="Left"
                                                 Loaded="OnSecretLoaded" PasswordChanged="OnSecretChanged"
                                                 Visibility="{Binding Secret, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="{loc:Loc Plugins_Save}" Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left" Command="{Binding SaveSettingsCommand}" Margin="0,0,0,20" />

                    <!-- Bible-source sync -->
                    <StackPanel Visibility="{Binding SelectedIsBibleSource, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{loc:Loc Plugins_Versions}" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Button x:Name="FetchVersionsButton" Content="{loc:Loc Plugins_FetchVersions}" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left" Command="{Binding FetchVersionsCommand}" Margin="0,0,0,8" />
                        <TextBlock Text="{loc:Loc Plugins_FilterVersions}" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="VersionFilterBox" Style="{StaticResource FieldTextBox}" Width="340" HorizontalAlignment="Left" Margin="0,0,0,8"
                                 Text="{Binding VersionFilter, UpdateSourceTrigger=PropertyChanged}" />
                        <ListBox x:Name="VersionsList" ItemsSource="{Binding VersionsView}"
                                 MaxHeight="220" Width="340" HorizontalAlignment="Left"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                 VirtualizingPanel.IsVirtualizingWhenGrouping="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center">
                                                <Run Text="{Binding Name, Mode=OneWay}" /><Run Text=" (" /><Run Text="{Binding Abbreviation, Mode=OneWay}" /><Run Text=")" />
                                            </TextBlock>
                                            <!-- Already in the library (matched by abbreviation): re-import only tops up missing verses. -->
                                            <Border Margin="6,0,0,0" Padding="4,0" CornerRadius="3" VerticalAlignment="Center"
                                                    Background="{DynamicResource SuccessSurfaceBrush}" BorderBrush="{DynamicResource SuccessBorderBrush}" BorderThickness="1"
                                                    Visibility="{Binding AlreadyDownloaded, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{loc:Loc Plugins_AlreadyDownloaded}" FontSize="9"
                                                           Foreground="{DynamicResource SuccessBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <!-- Group versions by language for easier scanning -->
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,2" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                        </ListBox>
                        <Button x:Name="ImportSelectedButton" Content="{loc:Loc Plugins_Import}" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left" Margin="0,8,0,0"
                                Command="{Binding ImportSelectedCommand}" />

                        <!-- Import progress: a whole-Bible download takes a while; show it's working. -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                            <ProgressBar IsIndeterminate="True" Width="140" Height="4" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ImportStatus}" Margin="10,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Error banner -->
        <Border Grid.Row="2" Background="{DynamicResource DangerSurfaceBrush}" BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="0,1,0,0" Padding="16,10"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}"
                       FontSize="13" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
