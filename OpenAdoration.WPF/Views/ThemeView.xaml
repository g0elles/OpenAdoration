<UserControl x:Class="OpenAdoration.WPF.Views.ThemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:views="clr-namespace:OpenAdoration.WPF.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ThemeViewModel}"
             Loaded="OnLoaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════ LEFT: Theme list ══ -->
        <Grid Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,1"
                    Padding="12,12,12,10">
                <Grid>
                    <TextBlock Text="Themes"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Content="+ New"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding NewThemeCommand}"
                            HorizontalAlignment="Right"
                            Padding="10,6" />
                </Grid>
            </Border>

            <!-- Theme list -->
            <Border Grid.Row="1"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <!-- Loading -->
                    <TextBlock Text="Loading…"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

                    <!-- Error -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="12"
                               VerticalAlignment="Top"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />

                    <!-- Empty state -->
                    <TextBlock Text="No themes yet. Click + New to add one."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBusy}"         Value="False" />
                                            <Condition Binding="{Binding HasError}"        Value="False" />
                                            <Condition Binding="{Binding Themes.Count}"    Value="0" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Theme rows -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Themes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SongRowCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Name + action buttons -->
                                            <Grid Grid.Row="0">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <!-- Default badge -->
                                                    <Border Background="{StaticResource AccentBrush}"
                                                            CornerRadius="2"
                                                            Padding="5,1"
                                                            Margin="6,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="DEFAULT"
                                                                   Foreground="White"
                                                                   FontSize="9"
                                                                   FontWeight="Bold" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right">
                                                    <Button Content="✎"
                                                            Style="{StaticResource IconButton}"
                                                            ToolTip="Edit"
                                                            Command="{Binding DataContext.EditThemeCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="0,0,2,0" />
                                                    <Button Content="✕"
                                                            Style="{StaticResource IconDangerButton}"
                                                            ToolTip="Delete"
                                                            Command="{Binding DataContext.DeleteThemeCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- Font info -->
                                            <TextBlock Grid.Row="1"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       Margin="0,3,0,0"
                                                       TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding FontFamily}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding FontSize}" />
                                                <Run Text="pt" />
                                            </TextBlock>

                                            <!-- Color swatches -->
                                            <StackPanel Grid.Row="2"
                                                        Orientation="Horizontal"
                                                        Margin="0,6,0,0">
                                                <Border Width="16" Height="16"
                                                        CornerRadius="2"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Background="{Binding BackgroundColor, Converter={StaticResource HexToBrush}}"
                                                        ToolTip="Background color" />
                                                <Border Width="16" Height="16"
                                                        CornerRadius="2"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Background="{Binding FontColor, Converter={StaticResource HexToBrush}}"
                                                        Margin="4,0,0,0"
                                                        ToolTip="Font color" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════ RIGHT: Edit / Placeholder ══ -->

        <views:AddEditThemeView Grid.Column="1"
                                DataContext="{Binding EditViewModel}"
                                Visibility="{Binding DataContext.IsEditing,
                                             RelativeSource={RelativeSource AncestorType=UserControl},
                                             Converter={StaticResource BoolToVis}}" />

        <Grid Grid.Column="1"
              Background="{StaticResource SurfaceBrush}"
              Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Select a theme from the list"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="16"
                           HorizontalAlignment="Center" />
                <TextBlock Text="or click + New to create one"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
