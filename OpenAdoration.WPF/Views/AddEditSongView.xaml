<UserControl x:Class="OpenAdoration.WPF.Views.AddEditSongView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:AddEditSongViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="{StaticResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header -->
            <RowDefinition Height="*"    />   <!-- Scrollable body -->
            <RowDefinition Height="Auto" />   <!-- Footer actions -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="Song"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="18"
                       FontWeight="SemiBold" />
        </Border>

        <!-- ── Body ── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,16">
            <StackPanel>

                <!-- Title -->
                <TextBlock Text="Title *"
                           Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldTextBox}"
                         Margin="0,4,0,16" />

                <!-- Author -->
                <TextBlock Text="Author"
                           Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldTextBox}"
                         Margin="0,4,0,24" />

                <!-- Sections list -->
                <TextBlock Text="SECTIONS"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="0,0,0,8" />

                <ItemsControl ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SongSectionViewModel}">
                            <Border Style="{StaticResource SectionCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*"    />
                                    </Grid.RowDefinitions>

                                    <!-- Section header: label + reorder + delete -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal">
                                            <Button Content="▲"
                                                    Style="{StaticResource IconButton}"
                                                    Command="{Binding MoveUpCommand}"
                                                    ToolTip="Move up" />
                                            <Button Content="▼"
                                                    Style="{StaticResource IconButton}"
                                                    Command="{Binding MoveDownCommand}"
                                                    ToolTip="Move down"
                                                    Margin="4,0" />
                                            <Button Content="✕"
                                                    Style="{StaticResource IconDangerButton}"
                                                    Command="{Binding DeleteCommand}"
                                                    ToolTip="Remove section" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Lyrics -->
                                    <TextBox Grid.Row="1"
                                             Text="{Binding Lyrics, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource LyricsTextBox}"
                                             MinHeight="90"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Quick-add section buttons — one per type, no dropdown needed -->
                <TextBlock Text="ADD SECTION"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="0,4,0,8" />
                <WrapPanel Margin="0,0,0,4">
                    <Button Content="+ Verse"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddSectionCommand}"
                            CommandParameter="Verse"
                            Margin="0,0,6,6" />
                    <Button Content="+ Chorus"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddSectionCommand}"
                            CommandParameter="Chorus"
                            Margin="0,0,6,6" />
                    <Button Content="+ Pre-Chorus"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddSectionCommand}"
                            CommandParameter="PreChorus"
                            Margin="0,0,6,6" />
                    <Button Content="+ Bridge"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddSectionCommand}"
                            CommandParameter="Bridge"
                            Margin="0,0,6,6" />
                    <Button Content="+ Intro"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddSectionCommand}"
                            CommandParameter="Intro"
                            Margin="0,0,6,6" />
                    <Button Content="+ Outro"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddSectionCommand}"
                            CommandParameter="Outro"
                            Margin="0,0,6,6" />
                    <Button Content="+ Tag"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddSectionCommand}"
                            CommandParameter="Tag"
                            Margin="0,0,0,6" />
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Footer ── -->
        <Border Grid.Row="2"
                Padding="24,12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}"
                        Margin="0,0,8,0" />
                <Button Content="Save Song"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
