<UserControl x:Class="OpenAdoration.WPF.Views.AddEditSongView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:AddEditSongViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceBrush}">

    <Grid>
        <!-- Busy overlay -->
        <Grid Panel.ZIndex="10"
              Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Saving…"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="16"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Main layout -->
        <DockPanel>

            <!-- ── Footer: error + action buttons ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <!-- Error message (left) -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               HorizontalAlignment="Left" />

                    <!-- Buttons (right) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Save Song"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable form ── -->
            <ScrollViewer x:Name="FormScroller" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,24">

                    <!-- Header -->
                    <TextBlock Text="{Binding FormTitle}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <!-- Title field -->
                    <TextBlock Text="TITLE" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="Song title"
                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14" />

                    <!-- Author field -->
                    <TextBlock Text="AUTHOR / ARTIST" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="Optional"
                             Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14" />

                    <!-- Classification field -->
                    <TextBlock Text="CLASSIFICATION" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="e.g. Worship, Hymn, Contemporary…"
                             Text="{Binding Classification, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,24" />

                    <!-- Section list -->
                    <ItemsControl ItemsSource="{Binding Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SongSectionViewModel}">
                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- Section header -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Content="▲"
                                                        Style="{StaticResource IconButton}"
                                                        Command="{Binding MoveUpCommand}"
                                                        ToolTip="Move up" />
                                                <Button Content="▼"
                                                        Style="{StaticResource IconButton}"
                                                        Command="{Binding MoveDownCommand}"
                                                        Margin="2,0"
                                                        ToolTip="Move down" />
                                                <Button Content="✕"
                                                        Style="{StaticResource IconDangerButton}"
                                                        Command="{Binding DeleteCommand}"
                                                        ToolTip="Remove section" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- Lyrics area -->
                                        <TextBox Grid.Row="1"
                                                 Style="{StaticResource LyricsTextBox}"
                                                 Text="{Binding Lyrics, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="80"
                                                 MaxHeight="200" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Add section buttons (below the list so they stay in view) -->
                    <TextBlock Text="ADD SECTION" Style="{StaticResource FieldLabel}" Margin="0,20,0,8" />
                    <WrapPanel>
                        <Button Content="+ Verse"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Verse"
                                Margin="0,0,6,6" />
                        <Button Content="+ Chorus"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Chorus"
                                Margin="0,0,6,6" />
                        <Button Content="+ Pre-Chorus"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="PreChorus"
                                Margin="0,0,6,6" />
                        <Button Content="+ Bridge"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Bridge"
                                Margin="0,0,6,6" />
                        <Button Content="+ Intro"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Intro"
                                Margin="0,0,6,6" />
                        <Button Content="+ Outro"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Outro"
                                Margin="0,0,6,6" />
                        <Button Content="+ Tag"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Tag"
                                Margin="0,0,6,6" />
                    </WrapPanel>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
