<UserControl x:Class="OpenAdoration.WPF.Views.AddEditSongView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:loc="clr-namespace:OpenAdoration.WPF.Localization"
             d:DataContext="{d:DesignInstance Type=vm:AddEditSongViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource SurfaceBrush}">

    <Grid>
        <!-- Busy overlay -->
        <Grid Panel.ZIndex="10"
              Background="#80000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc Common_Saving}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="16"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Main layout -->
        <DockPanel>

            <!-- ── Footer: error + action buttons ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource PrimaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <!-- Error message (left) -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource DangerBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               HorizontalAlignment="Left" />

                    <!-- Buttons (right) -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="{loc:Loc Common_Cancel}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="{loc:Loc SongEdit_Save}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Scrollable form ── -->
            <ScrollViewer x:Name="FormScroller" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,24">

                    <!-- Header -->
                    <TextBlock Text="{Binding FormTitle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <!-- Title field -->
                    <TextBlock Text="{loc:Loc SongEdit_Title}" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="{loc:Loc SongEdit_TitlePlaceholder}"
                             MaxLength="200"
                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14" />

                    <!-- Author field -->
                    <TextBlock Text="{loc:Loc SongEdit_Author}" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="{loc:Loc Common_Optional}"
                             Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14" />

                    <!-- Classification field -->
                    <TextBlock Text="{loc:Loc SongEdit_Classification}" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="{loc:Loc SongEdit_ClassificationPlaceholder}"
                             Text="{Binding Classification, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14" />

                    <!-- Copyright + CCLI (side by side) -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc SongEdit_Copyright}" Style="{StaticResource FieldLabel}" />
                            <TextBox Style="{StaticResource FieldTextBox}"
                                     Tag="{loc:Loc SongEdit_CopyrightPlaceholder}"
                                     Text="{Binding Copyright, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Loc SongEdit_Ccli}" Style="{StaticResource FieldLabel}" />
                            <TextBox Style="{StaticResource FieldTextBox}"
                                     Tag="{loc:Loc Common_Optional}"
                                     Text="{Binding CcliNumber, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <!-- Play order (verse order token string) -->
                    <TextBlock Text="{loc:Loc SongEdit_PlayOrder}" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource FieldTextBox}"
                             Tag="{loc:Loc SongEdit_PlayOrderPlaceholder}"
                             Text="{Binding VerseOrder, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4" />
                    <TextBlock Text="{loc:Loc SongEdit_PlayOrderHelp}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap" />

                    <!-- Theme (per-song override; default = inherit service/app theme) -->
                    <TextBlock Text="{loc:Loc SongEdit_Theme}" Style="{StaticResource FieldLabel}" />
                    <ComboBox Style="{StaticResource FieldComboBox}"
                              Width="260" HorizontalAlignment="Left"
                              ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding SelectedTheme}"
                              Margin="0,0,0,4">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{loc:Loc SongEdit_ThemeHelp}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap" />

                    <!-- Section list -->
                    <ItemsControl ItemsSource="{Binding Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SongSectionViewModel}">
                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- Section header -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- Color-coded verse-order token badge -->
                                                <Border Background="{Binding TypeColorHex, Converter={StaticResource HexToBrush}}"
                                                        CornerRadius="3"
                                                        Padding="6,1"
                                                        MinWidth="26"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Token}"
                                                               Foreground="White"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Content="▲"
                                                        Style="{StaticResource IconButton}"
                                                        Command="{Binding MoveUpCommand}"
                                                        ToolTip="{loc:Loc Common_MoveUp}" />
                                                <Button Content="▼"
                                                        Style="{StaticResource IconButton}"
                                                        Command="{Binding MoveDownCommand}"
                                                        Margin="2,0"
                                                        ToolTip="{loc:Loc Common_MoveDown}" />
                                                <Button Content="✕"
                                                        Style="{StaticResource IconDangerButton}"
                                                        Command="{Binding DeleteCommand}"
                                                        ToolTip="{loc:Loc SongEdit_RemoveSection}" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- Lyrics area -->
                                        <TextBox Grid.Row="1"
                                                 Style="{StaticResource LyricsTextBox}"
                                                 Text="{Binding Lyrics, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="80"
                                                 MaxHeight="200" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Add section buttons (below the list so they stay in view) -->
                    <TextBlock Text="{loc:Loc SongEdit_AddSection}" Style="{StaticResource FieldLabel}" Margin="0,20,0,8" />
                    <WrapPanel>
                        <Button Content="{loc:Loc SongEdit_AddVerse}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Verse"
                                Margin="0,0,6,6" />
                        <Button Content="{loc:Loc SongEdit_AddChorus}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Chorus"
                                Margin="0,0,6,6" />
                        <Button Content="{loc:Loc SongEdit_AddPreChorus}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="PreChorus"
                                Margin="0,0,6,6" />
                        <Button Content="{loc:Loc SongEdit_AddBridge}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Bridge"
                                Margin="0,0,6,6" />
                        <Button Content="{loc:Loc SongEdit_AddIntro}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Intro"
                                Margin="0,0,6,6" />
                        <Button Content="{loc:Loc SongEdit_AddOutro}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Outro"
                                Margin="0,0,6,6" />
                        <Button Content="{loc:Loc SongEdit_AddTag}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSectionCommand}"
                                CommandParameter="Tag"
                                Margin="0,0,6,6" />
                    </WrapPanel>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
