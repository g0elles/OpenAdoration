<UserControl x:Class="OpenAdoration.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:OpenAdoration.WPF.Localization"
             Loaded="OnLoaded">

    <Grid Background="{StaticResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- header -->
            <RowDefinition Height="*"    /> <!-- form -->
            <RowDefinition Height="Auto" /> <!-- error banner -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <TextBlock Text="{loc:Loc Settings_Title}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="16" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="520" HorizontalAlignment="Left" Margin="24,20">

                <TextBlock Text="{loc:Loc Settings_LanguageSection}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <TextBlock Text="{loc:Loc Settings_Language}" Style="{StaticResource FieldLabel}" />
                <ComboBox Style="{StaticResource FieldComboBox}"
                          Width="220" HorizontalAlignment="Left"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          Margin="0,0,0,4">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NativeName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="{loc:Loc Settings_LanguageHelp}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,24" TextWrapping="Wrap" />

                <TextBlock Text="{loc:Loc Settings_ChurchSection}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <TextBlock Text="{loc:Loc Settings_ChurchName}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource FieldTextBox}"
                         Tag="{loc:Loc Settings_ChurchNamePlaceholder}"
                         Text="{Binding ChurchName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4" />
                <TextBlock Text="{loc:Loc Settings_ChurchNameHelp}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap" />

                <TextBlock Text="{loc:Loc Settings_Ccli}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource FieldTextBox}"
                         Tag="{loc:Loc Settings_CcliPlaceholder}"
                         Text="{Binding ChurchCcliNumber, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4" />
                <TextBlock Text="{loc:Loc Settings_CcliHelp}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,24" TextWrapping="Wrap" />

                <TextBlock Text="{loc:Loc Settings_DefaultsSection}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <TextBlock Text="{loc:Loc Settings_AutoAdvance}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource FieldTextBox}"
                         Tag="{loc:Loc Settings_AutoAdvancePlaceholder}"
                         Text="{Binding DefaultAutoAdvanceSeconds, UpdateSourceTrigger=PropertyChanged}"
                         Width="120" HorizontalAlignment="Left"
                         Margin="0,0,0,4" />
                <TextBlock Text="{loc:Loc Settings_AutoAdvanceHelp}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap" />

                <TextBlock Text="{loc:Loc Settings_VersesPerSlide}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource FieldTextBox}"
                         Tag="1"
                         Text="{Binding DefaultBibleVersesPerSlide, UpdateSourceTrigger=PropertyChanged}"
                         Width="120" HorizontalAlignment="Left"
                         Margin="0,0,0,4" />
                <TextBlock Text="{loc:Loc Settings_VersesPerSlideHelp}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap" />

                <TextBlock Text="{loc:Loc Settings_AnnouncementDuration}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource FieldTextBox}"
                         Tag="25"
                         Text="{Binding AnnouncementDurationSeconds, UpdateSourceTrigger=PropertyChanged}"
                         Width="120" HorizontalAlignment="Left"
                         Margin="0,0,0,4" />
                <TextBlock Text="{loc:Loc Settings_AnnouncementDurationHelp}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap" />

                <TextBlock Text="{loc:Loc Settings_Transition}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource FieldTextBox}"
                         Tag="300"
                         Text="{Binding SlideTransitionMilliseconds, UpdateSourceTrigger=PropertyChanged}"
                         Width="120" HorizontalAlignment="Left"
                         Margin="0,0,0,4" />
                <TextBlock Text="{loc:Loc Settings_TransitionHelp}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,0,0,24" TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="{loc:Loc Settings_Save}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}" />
                    <TextBlock Text="{loc:Loc Settings_Saved}"
                               Foreground="#4CAF50"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Visibility="{Binding ShowSavedConfirmation, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Error banner -->
        <Border Grid.Row="2"
                Background="#3E1A1A"
                BorderBrush="{StaticResource DangerBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="13" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
