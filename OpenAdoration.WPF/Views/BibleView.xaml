<UserControl x:Class="OpenAdoration.WPF.Views.BibleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BibleViewModel}"
             Background="{StaticResource SurfaceBrush}">

    <!-- Ctrl+↓/↑ extend / shrink the verse selection -->
    <UserControl.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="Down" Command="{Binding ExpandSelectionDownCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="Up"   Command="{Binding ExpandSelectionUpCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <!-- Books grouped by Testament (OT / NT) -->
        <CollectionViewSource x:Key="GroupedBooks" Source="{Binding Books}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="BookNumber" Direction="Ascending" />
            </CollectionViewSource.SortDescriptions>
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Testament" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <!-- Group header: OLD TESTAMENT / NEW TESTAMENT -->
        <Style x:Key="TestamentHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize"   Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin"     Value="12,10,0,4" />
        </Style>

        <!--
            BookTreeItem — ListBoxItem with no background decoration.
            Hover / selected highlighting is applied inside the DataTemplate
            (on the book-name row only), so chapter tiles below it stay unaffected.
        -->
        <Style x:Key="BookTreeItem" TargetType="ListBoxItem">
            <Setter Property="Background"                 Value="Transparent" />
            <Setter Property="Foreground"                 Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding"                    Value="0" />
            <Setter Property="Cursor"                     Value="Hand" />
            <Setter Property="FocusVisualStyle"           Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter HorizontalAlignment="Stretch" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chapter tile buttons inside the tree -->
        <Style x:Key="ChapterTileButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width"           Value="32" />
            <Setter Property="Height"          Value="30" />
            <Setter Property="Margin"          Value="2" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Highlight the tile for the currently selected chapter -->
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource IntEquality}">
                            <Binding />
                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}"
                                     Path="DataContext.SelectedChapter" />
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background"  Value="{StaticResource AccentBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Foreground"  Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Dark-theme checkbox for verse rows — IsHitTestVisible=False so row click handles selection -->
        <Style x:Key="VerseCheckBox" TargetType="CheckBox">
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd" Width="16" Height="16" CornerRadius="3"
                                Background="Transparent"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1.5">
                            <Path x:Name="Check"
                                  Data="M2,8 L6,12 L14,4"
                                  Stroke="White" StrokeThickness="2"
                                  Visibility="Collapsed" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"    Property="Background"  Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Bd"    Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Check" Property="Visibility"  Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- Global busy overlay (load / search) -->
        <Grid Panel.ZIndex="20"
              Background="#B0000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Loading…"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Empty-state: no Bible imported yet -->
        <Grid Visibility="{Binding HasVersions, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
                <TextBlock Text="📖" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,14" />
                <TextBlock Text="No Bible version imported"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" TextAlignment="Center" TextWrapping="Wrap"
                           Margin="0,0,0,24">
                    Import a Bible file to get started. Supported formats:
                    Zefania XML, OSIS XML, USFX XML, and JSON.
                </TextBlock>
                <Button Content="Import Bible File…"
                        Style="{StaticResource PrimaryButton}"
                        Padding="20,10" HorizontalAlignment="Center"
                        Click="OnImportClick" />
            </StackPanel>
        </Grid>

        <!-- Main browser (shown once a version is imported) -->
        <DockPanel Visibility="{Binding HasVersions, Converter={StaticResource BoolToVis}}">

            <!-- ── Reference bar ─────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Reference/keyword input with autocomplete -->
                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <TextBox x:Name="ReferenceBox"
                                 Style="{StaticResource FieldTextBox}"
                                 Tag="{Binding ReferenceBarPlaceholder}"
                                 Text="{Binding ReferenceInput, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ParseReferenceCommand}" />
                                <KeyBinding Key="Escape" Command="{Binding ClearReferenceCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>

                        <!-- Book autocomplete popup (reference mode only) -->
                        <Popup IsOpen="{Binding HasBookSuggestions, Mode=OneWay}"
                               PlacementTarget="{x:Reference ReferenceBox}"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True">
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4">
                                <ItemsControl ItemsSource="{Binding BookSuggestions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="SugBd" Padding="12,7" Cursor="Hand"
                                                    Background="Transparent">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                        Command="{Binding DataContext.SelectBookSuggestionCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                </Border.InputBindings>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13" />
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource ActiveNavBrush}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Version selector (+ optional secondary for dual-version projection) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,6,0">
                        <ComboBox ItemsSource="{Binding Versions}"
                                  SelectedItem="{Binding SelectedVersion}"
                                  Style="{StaticResource FieldComboBox}"
                                  MinWidth="140">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox ItemsSource="{Binding Versions}"
                                  SelectedItem="{Binding SecondaryVersion}"
                                  Style="{StaticResource FieldComboBox}"
                                  MinWidth="120" Margin="6,0,0,0"
                                  ToolTip="Optional second version, stacked under the first on each slide">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="✕"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ClearSecondaryVersionCommand}"
                                Padding="8,4" Margin="4,0,0,0"
                                ToolTip="Clear second version"
                                Visibility="{Binding HasSecondaryVersion, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <!-- Keyword mode toggle -->
                    <ToggleButton Grid.Column="2"
                                  Content="≡ Keyword"
                                  IsChecked="{Binding IsKeywordMode}"
                                  Style="{StaticResource AlignToggleButton}"
                                  Padding="10,6" Margin="0,0,6,0"
                                  ToolTip="Toggle keyword search mode" />

                    <!-- Phrase vs keyword (only meaningful in keyword search mode) -->
                    <ToggleButton Grid.Column="3"
                                  Content="&quot; &quot; Phrase"
                                  IsChecked="{Binding IsPhraseSearch}"
                                  Style="{StaticResource AlignToggleButton}"
                                  Padding="10,6" Margin="0,0,6,0"
                                  Visibility="{Binding IsKeywordMode, Converter={StaticResource BoolToVis}}"
                                  ToolTip="Match the exact phrase instead of all words" />

                    <!-- Clear input -->
                    <Button Grid.Column="4" Content="✕"
                            Style="{StaticResource IconButton}"
                            Command="{Binding ClearReferenceCommand}"
                            ToolTip="Clear" />
                </Grid>
            </Border>

            <!-- ── Import progress strip ──────────────────────────────────── -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1" Padding="14,8"
                    Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{Binding ImportStatusMessage}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                        <ProgressBar Height="4" Margin="0,5,0,0"
                                     Value="{Binding ImportProgress, Mode=OneWay}"
                                     Maximum="{Binding ImportTotal, Mode=OneWay}"
                                     IsIndeterminate="{Binding IsImportIndeterminate, Mode=OneWay}"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="{StaticResource BorderBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,4" VerticalAlignment="Center"
                            Command="{Binding CancelImportCommand}" />
                </Grid>
            </Border>

            <!-- ── Import summary bar ─────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Background="#162016" Padding="16,8"
                    Visibility="{Binding HasImportSummary, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ImportSummary}" Foreground="#4CAF50" FontSize="12" />
            </Border>

            <!-- ── Error bar ──────────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Background="#3E1A1A" Padding="16,8"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}" FontSize="12" />
            </Border>

            <!-- ── Action bar (bottom) ────────────────────────────────────── -->
            <!--
                Prev/Next are intentionally absent here.
                The main window projection bar owns slide navigation.
                Use ▶▶ Project to push the current verse selection to screen.
            -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0" Padding="12,8">
                <DockPanel>
                    <!-- Manage buttons (right-aligned) -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Import…"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6" Margin="0,0,6,0"
                                IsEnabled="{Binding CanImport}"
                                Click="OnImportClick" />
                        <Button Content="Delete Version"
                                Style="{StaticResource DangerButton}"
                                Padding="10,6"
                                IsEnabled="{Binding CanDeleteVersion}"
                                Command="{Binding DeleteVersionCommand}" />
                    </StackPanel>

                    <!-- Live-service controls (left) -->
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton Content="🔒 Freeze"
                                      IsChecked="{Binding IsFrozen, Mode=TwoWay}"
                                      Style="{StaticResource AlignToggleButton}"
                                      Padding="12,6" Margin="0,0,12,0"
                                      ToolTip="Hold current slide on screen while you navigate to the next" />
                        <Button Content="▶▶ Project"
                                Style="{StaticResource PrimaryButton}"
                                Padding="16,6"
                                Command="{Binding ProjectSelectedCommand}"
                                IsEnabled="{Binding HasSelection}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Slide preview panel (above action bar) ─────────────────── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource PrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0" Padding="14,10"
                    Visibility="{Binding HasSlidePreview, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{Binding SlidePreviewText}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontStyle="Italic"
                               TextWrapping="Wrap" MaxHeight="60"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding SlidePreviewLabel}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" Margin="0,4,0,0"
                               HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- ── Two-column body: tree (books+chapters) | verses ────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />   <!-- Books + inline chapter tiles -->
                    <ColumnDefinition Width="1" />     <!-- Divider -->
                    <ColumnDefinition Width="*" />     <!-- Verses -->
                </Grid.ColumnDefinitions>

                <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}" />

                <!-- ── Books + chapters (tree-like) ── -->
                <ListBox Grid.Column="0"
                         x:Name="BooksListBox"
                         ItemsSource="{Binding Source={StaticResource GroupedBooks}}"
                         SelectedItem="{Binding SelectedBook}"
                         ItemContainerStyle="{StaticResource BookTreeItem}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Book name row: highlighted when selected/hovered -->
                                <Border x:Name="BookRow" Padding="12,8" Background="Transparent">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="False" />
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="{StaticResource ActiveNavBrush}" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Chapter tiles: visible only when this book is selected -->
                                <ItemsControl
                                    ItemsSource="{Binding DataContext.Chapters, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    Margin="8,4,8,8">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Style="{StaticResource ChapterTileButton}"
                                                    Command="{Binding DataContext.SelectChapterCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <!-- OT / NT group headers -->
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name, Converter={StaticResource TestamentToLabel}}"
                                               Style="{StaticResource TestamentHeader}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                </ListBox>

                <!-- ── Verses (checkable rows) ── -->
                <Grid Grid.Column="2">

                    <!-- Search results header (keyword mode) -->
                    <Border Background="{StaticResource PrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="14,8" VerticalAlignment="Top"
                            Panel.ZIndex="1"
                            Visibility="{Binding IsSearchActive, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="Search results for &quot;" /><Run Text="{Binding ReferenceInput, Mode=OneWay}" /><Run Text="&quot;" />
                        </TextBlock>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearchActive}" Value="True">
                                        <Setter Property="Margin" Value="0,38,0,0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <ItemsControl ItemsSource="{Binding CheckableVerses}"
                                      Foreground="{StaticResource TextPrimaryBrush}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:BibleVerseCheckItem}">
                                    <Border x:Name="RowBorder"
                                            Cursor="Hand" Padding="12,8"
                                            Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                Command="{Binding DataContext.SelectVerseCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26" />
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsChecked}"
                                                      Style="{StaticResource VerseCheckBox}" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Verse.Verse}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Top"
                                                       TextAlignment="Right"
                                                       Margin="0,2,6,0" />

                                            <StackPanel Grid.Column="2">
                                                <!-- Book/chapter reference shown only in search results -->
                                                <TextBlock Text="{Binding Verse.Reference}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,2">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsSearchActive,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBlock Text="{Binding Verse.Text}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap"
                                                           LineHeight="20" />
                                            </StackPanel>
                                        </Grid>

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource ActiveNavBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsChecked}" Value="False" />
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="#20FFFFFF" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Placeholder: no chapter selected and no search active -->
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedChapter}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        Select a book, then tap a chapter number
                    </TextBlock>
                </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
