<UserControl x:Class="OpenAdoration.WPF.Views.MediaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenAdoration.WPF.ViewModels"
             xmlns:loc="clr-namespace:OpenAdoration.WPF.Localization"
             xmlns:behaviors="clr-namespace:OpenAdoration.WPF.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MediaViewModel}"
             Loaded="OnLoaded"
             Background="{DynamicResource SurfaceBrush}">

    <Grid>
        <!-- Busy overlay -->
        <Border Panel.ZIndex="20"
                Background="#AA1E1E2E"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{loc:Loc Common_Loading}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

        <DockPanel>
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource PrimaryBrush}"
                    Padding="20,14">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc Media_Title}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,20,0" />
                        <!-- Media / Backgrounds subsection toggle -->
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                ClipToBounds="True"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton Content="{loc:Loc Media_TabMedia}"
                                              Style="{StaticResource AlignToggleButton}"
                                              IsChecked="{Binding IsMediaTab, Mode=OneWay}"
                                              Command="{Binding ShowMediaTabCommand}" />
                                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" />
                                <ToggleButton Content="{loc:Loc Media_TabBackgrounds}"
                                              Style="{StaticResource AlignToggleButton}"
                                              IsChecked="{Binding ShowBackgrounds, Mode=OneWay}"
                                              Command="{Binding ShowBackgroundsTabCommand}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{loc:Loc Media_ImportFolder}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="16,7"
                                Command="{Binding ImportFolderCommand}" />
                        <Button Content="{loc:Loc Media_Import}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="16,7" Margin="8,0,0,0"
                                Command="{Binding ImportFileCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Error bar -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource DangerBrush}"
                    Padding="20,10"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="White"
                           FontSize="13" />
            </Border>

            <!-- Main content -->
            <Grid>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasDisplayed, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="&#xE91B;"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="56"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />
                    <TextBlock Text="{loc:Loc Media_Empty}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{loc:Loc Media_EmptyHelp}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24" />
                    <Button x:Name="ImportMediaCtaButton"
                            Content="{loc:Loc Media_ImportCta}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="20,9"
                            HorizontalAlignment="Center"
                            Command="{Binding ImportFileCommand}" />
                </StackPanel>

                <!-- Media grid -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasDisplayed, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding DisplayedFiles}" Margin="12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Card -->
                                <Border Width="180" Margin="8"
                                        CornerRadius="6"
                                        BorderThickness="1.5"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        Background="{DynamicResource PrimaryBrush}"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource IntEquality}">
                                                            <Binding Path="Id" />
                                                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}"
                                                                     Path="DataContext.SelectedFile.Id"
                                                                     FallbackValue="0"
                                                                     TargetNullValue="0" />
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel>
                                        <!-- Thumbnail area -->
                                        <Border Height="90"
                                                CornerRadius="6,6,0,0"
                                                ClipToBounds="True"
                                                Background="#2A2A3E">
                                            <Grid>
                                                <!-- Thumbnail: shell (images + most videos) → FFmpeg fallback (HEVC) -->
                                                <Image behaviors:ThumbnailImage.Source="{Binding FilePath}"
                                                       Stretch="UniformToFill" />

                                                <!-- Video icon overlay — visible only when Type is Video -->
                                                <TextBlock Text="&#xE714;"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="32"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="Video">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <!-- Filename + actions -->
                                        <StackPanel Margin="10,8,10,10">
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding FileName}"
                                                       Margin="0,0,0,8" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Style="{StaticResource PrimaryButton}"
                                                        FontSize="11"
                                                        Padding="0,5"
                                                        Command="{Binding DataContext.ProjectFileCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock>
                                                        <Run Text="▶ " />
                                                        <Run Text="{loc:Loc Common_Project}" />
                                                    </TextBlock>
                                                </Button>

                                                <Button Grid.Column="1"
                                                        Content="✕"
                                                        Style="{StaticResource IconDangerButton}"
                                                        Margin="6,0,0,0"
                                                        ToolTip="{loc:Loc Common_Delete}"
                                                        Command="{Binding DataContext.DeleteFileCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
